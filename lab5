    root1 = build_expression_tree(tokens1)
    print(f"Результат вычисления: {evaluate(root1)}")
    print(f"Префиксная форма (Пункт 3): {to_prefix(root1)}")
    print("\nСтруктура дерева в консоли:")
    print_tree(root1)
    
